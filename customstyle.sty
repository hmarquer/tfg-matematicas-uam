%Theorem environment definitions
\newtheoremstyle{definitionstyle}
	{6pt} % Space above
    {6pt} % Space below
    {\color{defncolor}} % Body font
    {} % Indent amount
    {\bfseries} % Head font
    {.} % Punctuation after head
    {0.5em} % Space after head
    {\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}} % Head spec

\newtheoremstyle{examplestyle}
    {6pt}{6pt}
    {\color{ejemcolor}}{}
    {\bfseries}
    {.}
    {0.5em}
    {\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}}

\newtheoremstyle{exercisestyle}
    {6pt}{6pt}
    {\color{ejercolor}}{}
    {\bfseries}
    {.}
    {0.5em}
    {\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}}

\newtheoremstyle{propositionstyle}
    {6pt}{6pt}
    {\itshape\color{propcolor}}{}
    {\bfseries}
    {.}
    {0.5em}
    {\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}}

\newtheoremstyle{remarkstyle}
    {6pt}{6pt}
    {\color{remarkcolor}}{}
    {\itshape}
    {.}
    {0.5em}
    {\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}}

\newenvironment{dem}[1][]{%\par
    \textbf{\textit{Demostración}\ifx\relax#1\relax\else{ (#1)}\fi:}
}{\hfill \qedsymbol\par}

\newenvironment{sol}[1][]{%\par
   \textbf{\textit{Solución}\ifx\relax#1\relax\else{ (#1)}\fi:}
}{\par}

\NewDocumentEnvironment{enu}{O{1} O{}}{
    \newcommand{\colnum}{#1}
    \if\relax\colnum\relax
        \renewcommand{\colnum}{1}
    \fi
    \ifnum\colnum=1
        \begin{enumerate}[#2]
    \else
        \begin{multicols}{#1}
            \begin{enumerate}[#2]
    \fi
}{\ifnum\colnum=1 \end{enumerate} \else \end{enumerate}\end{multicols} \fi}

