        \begin{enumerate}[#2]
    \else
    % Evita el espacio vertical extra que multicols anade antes y despues
    \setlength{\multicolsep}{6pt}
    % \setlength{\premulticols}{4pt}
    % \setlength{\postmulticols}{4pt}
        \begin{multicols}{#1}
            \begin{enumerate}[#2]
    \fi
}{\ifnum\colnum=1 \end{enumerate} \else \end{enumerate}\end{multicols} \fi}

